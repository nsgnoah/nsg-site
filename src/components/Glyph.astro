---
interface Props {
  index: number;
}

const { index } = Astro.props;
---

{
  index === 0 && (
    <svg viewBox="0 0 200 120" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <rect x="20" y="20" width="160" height="80" fill="none" stroke="rgba(10,10,10,0.55)" />
      <rect x="32" y="32" width="60" height="56" fill="none" stroke="rgba(10,10,10,0.55)" />
      <line x1="100" y1="32" x2="170" y2="32" stroke="rgba(10,10,10,0.55)" />
      <line x1="100" y1="48" x2="170" y2="48" stroke="rgba(10,10,10,0.55)" />
      <line x1="100" y1="64" x2="160" y2="64" stroke="rgba(10,10,10,0.55)" />
      <rect x="100" y="78" width="40" height="10" fill="var(--red)" />
    </svg>
  )
}

{
  index === 1 && (
    <svg viewBox="0 0 200 120" aria-hidden="true">
      <polygon points="40,90 100,30 160,90" fill="none" stroke="rgba(10,10,10,0.55)" />
      <polygon points="40,90 100,60 160,90" fill="none" stroke="rgba(10,10,10,0.55)" />
      <line x1="20" y1="100" x2="180" y2="100" stroke="var(--red)" />
      <circle cx="100" cy="60" r="3" fill="var(--red)" />
    </svg>
  )
}

{
  index === 2 && (
    <svg viewBox="0 0 200 120" aria-hidden="true">
      <rect x="30" y="30" width="60" height="14" fill="none" stroke="rgba(10,10,10,0.55)" />
      <rect x="30" y="52" width="140" height="14" fill="none" stroke="rgba(10,10,10,0.55)" />
      <rect x="30" y="74" width="100" height="14" fill="none" stroke="rgba(10,10,10,0.55)" />
      <rect x="30" y="74" width="50" height="14" fill="var(--red)" />
    </svg>
  )
}

{
  index === 3 && (
    <svg viewBox="0 0 200 120" aria-hidden="true">
      <line x1="20" y1="60" x2="180" y2="60" stroke="rgba(10,10,10,0.55)" />
      <polyline
        points="20,60 50,40 80,80 110,30 140,70 180,50"
        fill="none"
        stroke="var(--red)"
        stroke-width="1.5"
      />
      <circle cx="50" cy="40" r="3" fill="rgba(10,10,10,0.55)" />
      <circle cx="80" cy="80" r="3" fill="rgba(10,10,10,0.55)" />
      <circle cx="110" cy="30" r="3" fill="var(--red)" />
      <circle cx="140" cy="70" r="3" fill="rgba(10,10,10,0.55)" />
    </svg>
  )
}
