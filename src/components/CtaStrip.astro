---
interface Props {
  title: string;
  // Optional styled follow-on phrase, rendered as <span class="cta-answer">.
  // Kept as a separate text prop (not raw HTML in `title`) so this heading has
  // no set:html sink — every value stays plain text and auto-escaped.
  answer?: string;
  note: string;
  primaryText?: string;
  primaryHref?: string;
  ghostText?: string;
  ghostHref?: string;
}

const {
  title,
  answer,
  note,
  primaryText = 'Get in touch',
  primaryHref = '/contact',
  ghostText,
  ghostHref = 'mailto:noah@nsgsolutions.co'
} = Astro.props;
---

<section class="cta">
  <div class="container">
    <div class="cta-inner">
      <div>
        <h2>
          {title}{
            answer && (
              <>
                {' '}
                <span class="cta-answer">{answer}</span>
              </>
            )
          }
        </h2>
        {note && <div class="cta-note">{note}</div>}
      </div>
      <div class="cta-actions">
        <a href={primaryHref} class="btn btn-primary">{primaryText} <span class="arr">→</span></a>
        {
          ghostText && (
            <a href={ghostHref} class="btn btn-ghost">
              {ghostText}
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>
