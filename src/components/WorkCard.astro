---
import Glyph from './Glyph.astro';

interface Props {
  index: number;
  kind: string;
  industry: string;
  year: string;
  title: string;
  desc: string;
  tag: string;
}

const { index, kind, industry, year, title, desc, tag } = Astro.props;
const ariaLabel = `${title} — ${industry}, ${year}. Get in touch to walk through this engagement.`;
---

<a class="work-card" href="/contact" aria-label={ariaLabel}>
  <div class="work-thumb">
    <span class="work-thumb-label">{tag}</span>
    <Glyph index={index} />
  </div>
  <div class="work-meta">
    <span>{kind}</span>
    <span class="industry">{industry} · {year}</span>
  </div>
  <h3>{title}</h3>
  <p class="desc">{desc}</p>
  <div class="read"><span>Walk through this one</span><span class="arr">→</span></div>
</a>
