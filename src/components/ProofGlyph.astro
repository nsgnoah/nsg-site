---
interface Props {
  variant: 'consolidation' | 'stage-builder' | 'ai-pipeline';
}

const { variant } = Astro.props;
---

<div class="proof-glyph" aria-hidden="true">
  {variant === 'consolidation' && (
    <svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
      <!-- 3+2 tool grid -->
      <rect x="6" y="37" width="13" height="10" stroke="currentColor" stroke-width="1.5" opacity="0.5" />
      <line x1="9" y1="41" x2="16" y2="41" stroke="currentColor" stroke-width="1.5" opacity="0.35" />

      <rect x="23" y="37" width="13" height="10" stroke="currentColor" stroke-width="1.5" opacity="0.5" />
      <line x1="26" y1="41" x2="33" y2="41" stroke="currentColor" stroke-width="1.5" opacity="0.35" />

      <rect x="40" y="37" width="13" height="10" stroke="currentColor" stroke-width="1.5" opacity="0.5" />
      <line x1="43" y1="41" x2="50" y2="41" stroke="currentColor" stroke-width="1.5" opacity="0.35" />

      <rect x="14" y="51" width="13" height="10" stroke="currentColor" stroke-width="1.5" opacity="0.5" />
      <line x1="17" y1="55" x2="24" y2="55" stroke="currentColor" stroke-width="1.5" opacity="0.35" />

      <rect x="31" y="51" width="13" height="10" stroke="currentColor" stroke-width="1.5" opacity="0.5" />
      <line x1="34" y1="55" x2="41" y2="55" stroke="currentColor" stroke-width="1.5" opacity="0.35" />

      <!-- merge path: bottom tools → arrow entry -->
      <path
        d="M42 55 C48 51 54 49 62 49"
        stroke="currentColor"
        stroke-width="1.5"
        opacity="0.25"
        stroke-dasharray="3 3"
      />

      <!-- red arrow centered in gap (grid 53 → app 82) -->
      <path d="M62 49 H70 L66 45 M70 49 L66 53" stroke="var(--red)" stroke-width="1.5" stroke-linecap="square" />

      <!-- unified app — ServiceGlyph tier 1 landscape dashboard -->
      <rect x="82" y="27" width="70" height="44" stroke="currentColor" stroke-width="1.5" />
      <rect x="88" y="33" width="28" height="20" stroke="currentColor" stroke-width="1.5" />
      <line x1="120" y1="33" x2="146" y2="33" stroke="currentColor" stroke-width="1.5" />
      <line x1="120" y1="39" x2="146" y2="39" stroke="currentColor" stroke-width="1.5" />
      <line x1="120" y1="45" x2="136" y2="45" stroke="currentColor" stroke-width="1.5" />
      <rect x="120" y="51" width="20" height="6" fill="var(--red)" />
      <line x1="88" y1="57" x2="146" y2="57" stroke="currentColor" stroke-width="1.5" opacity="0.35" />
    </svg>
  )}
  {variant === 'stage-builder' && (
    <svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M12 78 L18 58 L42 56 L38 76 Z"
        stroke="currentColor"
        stroke-width="1.5"
        opacity="0.4"
        stroke-dasharray="4 3"
      />

      <path d="M62 66 H70 L66 62 M70 66 L66 70" stroke="var(--red)" stroke-width="1.5" stroke-linecap="square" />

      <!-- proscenium backdrop -->
      <rect x="88" y="28" width="64" height="40" stroke="currentColor" stroke-width="1.5" />

      <!-- stage deck -->
      <rect x="90" y="70" width="60" height="10" stroke="currentColor" stroke-width="1.5" />

      <!-- red front lip -->
      <line x1="86" y1="84" x2="154" y2="84" stroke="var(--red)" stroke-width="2" stroke-linecap="square" />
    </svg>
  )}
  {variant === 'ai-pipeline' && (
    <svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="6" y="42" width="28" height="36" stroke="currentColor" stroke-width="1.5" />
      <line x1="12" y1="52" x2="28" y2="52" stroke="currentColor" stroke-width="1.5" opacity="0.35" />
      <line x1="12" y1="60" x2="24" y2="60" stroke="currentColor" stroke-width="1.5" opacity="0.35" />
      <line x1="12" y1="68" x2="26" y2="68" stroke="currentColor" stroke-width="1.5" opacity="0.35" />

      <path d="M36 60 H46 L42 56 M46 60 L42 64" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />

      <circle cx="68" cy="60" r="18" stroke="currentColor" stroke-width="1.5" />
      <circle cx="68" cy="60" r="6" fill="var(--nsg-teal)" />

      <path d="M86 60 H96 L92 56 M96 60 L92 64" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />

      <rect x="100" y="38" width="36" height="44" stroke="currentColor" stroke-width="1.5" />
      <line x1="106" y1="48" x2="130" y2="48" stroke="currentColor" stroke-width="1.5" />
      <line x1="106" y1="56" x2="128" y2="56" stroke="currentColor" stroke-width="1.5" />
      <line x1="106" y1="64" x2="122" y2="64" stroke="currentColor" stroke-width="1.5" />
      <rect x="106" y="72" width="22" height="6" fill="var(--nsg-teal)" opacity="0.75" />
    </svg>
  )}
</div>
