---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const isActive = (path: string) => currentPath === path;
---

<nav class="nav" aria-label="Primary navigation" data-mobile-nav>
  <div class="container nav-inner">
    <a href="/" class="wordmark" aria-label="NSG home">
      NSG<span class="accent">.</span>
    </a>
    <button
      class="nav-toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="primary-menu"
      data-nav-toggle
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
    <ul class="nav-links" id="primary-menu" data-nav-menu>
      <li>
        <a
          class="nav-link"
          href="/services"
          aria-current={isActive('/services') ? 'page' : undefined}>Services</a
        >
      </li>
      <li>
        <a class="nav-link" href="/about" aria-current={isActive('/about') ? 'page' : undefined}
          >About</a
        >
      </li>
      <li>
        <a class="nav-cta" href="/contact">Get in Touch →</a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const mobileNav = document.querySelector<HTMLElement>('[data-mobile-nav]');
  const navToggle = mobileNav?.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const navMenu = mobileNav?.querySelector<HTMLElement>('[data-nav-menu]');
  const mainEl = document.querySelector('main');
  const footerEl = document.querySelector('footer');

  if (mobileNav && navToggle && navMenu) {
    let lastFocusBeforeOpen: HTMLElement | null = null;

    const getFocusables = (): HTMLElement[] =>
      Array.from(mobileNav.querySelectorAll<HTMLElement>('a[href], button:not([disabled])')).filter(
        (el) =>
          typeof el.checkVisibility === 'function' ? el.checkVisibility() : el.offsetParent !== null
      );

    const setOpen = (open: boolean) => {
      const wasOpen = mobileNav.getAttribute('data-open') === 'true';
      if (open === wasOpen) return;

      mobileNav.setAttribute('data-open', open ? 'true' : 'false');
      navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      navToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      document.body.classList.toggle('nav-open', open);
      mainEl?.toggleAttribute('inert', open);
      footerEl?.toggleAttribute('inert', open);

      if (open) {
        lastFocusBeforeOpen =
          document.activeElement instanceof HTMLElement ? document.activeElement : null;
        requestAnimationFrame(() => {
          navMenu.querySelector('a')?.focus();
        });
      } else {
        (lastFocusBeforeOpen ?? navToggle).focus();
        lastFocusBeforeOpen = null;
      }
    };

    navToggle.addEventListener('click', () => {
      setOpen(navToggle.getAttribute('aria-expanded') !== 'true');
    });

    navMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && mobileNav.getAttribute('data-open') === 'true') {
        setOpen(false);
        return;
      }
      if (
        event.key !== 'Tab' ||
        mobileNav.getAttribute('data-open') !== 'true' ||
        !window.matchMedia('(max-width: 720px)').matches
      ) {
        return;
      }

      const focusables = getFocusables();
      if (focusables.length === 0) return;

      const active = document.activeElement;
      const i = active instanceof HTMLElement ? focusables.indexOf(active) : -1;
      if (i === -1) return;

      if (!event.shiftKey && i === focusables.length - 1) {
        event.preventDefault();
        focusables[0].focus();
      } else if (event.shiftKey && i === 0) {
        event.preventDefault();
        focusables[focusables.length - 1].focus();
      }
    });

    window.addEventListener('resize', () => {
      if (window.matchMedia('(min-width: 721px)').matches) setOpen(false);
    });
  }
</script>
