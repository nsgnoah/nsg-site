---
interface Props {
  tier: 1 | 2 | 3 | 'step' | 'person';
  step?: number;
}

const { tier, step = 1 } = Astro.props;
---

<div class="service-glyph" aria-hidden="true">
  {
    tier === 'person' && (
      <svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="80" cy="38" r="18" stroke="currentColor" stroke-width="1.5" />
        <path
          d="M44 98c0-19.882 16.118-36 36-36s36 16.118 36 36"
          stroke="currentColor"
          stroke-width="1.5"
        />
        <rect x="118" y="22" width="22" height="30" stroke="currentColor" stroke-width="1.5" />
        <line x1="124" y1="30" x2="134" y2="30" stroke="currentColor" stroke-width="1.5" />
        <line x1="124" y1="38" x2="130" y2="38" stroke="currentColor" stroke-width="1.5" />
      </svg>
    )
  }

  {
    tier === 1 && (
      <svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="12" y="16" width="136" height="88" stroke="currentColor" stroke-width="1.5" />
        <rect x="24" y="28" width="52" height="40" stroke="currentColor" stroke-width="1.5" />
        <line x1="84" y1="28" x2="136" y2="28" stroke="currentColor" stroke-width="1.5" />
        <line x1="84" y1="40" x2="136" y2="40" stroke="currentColor" stroke-width="1.5" />
        <line x1="84" y1="52" x2="120" y2="52" stroke="currentColor" stroke-width="1.5" />
        <rect x="84" y="68" width="36" height="10" fill="var(--red)" />
        <line
          x1="24"
          y1="88"
          x2="136"
          y2="88"
          stroke="currentColor"
          stroke-width="1.5"
          opacity="0.35"
        />
      </svg>
    )
  }

  {
    tier === 2 && (
      <svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="16" y="36" width="36" height="36" stroke="currentColor" stroke-width="1.5" />
        <rect x="108" y="36" width="36" height="36" stroke="currentColor" stroke-width="1.5" />
        <rect x="62" y="72" width="36" height="28" stroke="currentColor" stroke-width="1.5" />
        <path d="M52 54H62M98 54H108M80 72V54" stroke="currentColor" stroke-width="1.5" />
        <circle cx="80" cy="54" r="4" fill="var(--red)" />
        <path d="M16 54H8M152 54H144" stroke="currentColor" stroke-width="1.5" opacity="0.4" />
      </svg>
    )
  }

  {
    tier === 3 && (
      <svg viewBox="0 0 160 120" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="80" cy="44" r="22" stroke="currentColor" stroke-width="1.5" />
        <circle cx="80" cy="44" r="8" fill="var(--nsg-teal)" />
        <line x1="80" y1="66" x2="80" y2="82" stroke="currentColor" stroke-width="1.5" />
        <line x1="48" y1="82" x2="112" y2="82" stroke="currentColor" stroke-width="1.5" />
        <line x1="48" y1="82" x2="48" y2="96" stroke="currentColor" stroke-width="1.5" />
        <line x1="80" y1="82" x2="80" y2="96" stroke="currentColor" stroke-width="1.5" />
        <line x1="112" y1="82" x2="112" y2="96" stroke="currentColor" stroke-width="1.5" />
        <rect x="40" y="96" width="16" height="10" fill="var(--nsg-teal)" opacity="0.35" />
        <rect x="72" y="96" width="16" height="10" fill="var(--nsg-teal)" opacity="0.55" />
        <rect x="104" y="96" width="16" height="10" fill="var(--nsg-teal)" />
      </svg>
    )
  }

  {
    tier === 'step' && step === 1 && (
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="8" y="10" width="32" height="28" stroke="currentColor" stroke-width="1.5" />
        <line x1="14" y1="18" x2="34" y2="18" stroke="currentColor" stroke-width="1.5" />
        <line x1="14" y1="24" x2="28" y2="24" stroke="currentColor" stroke-width="1.5" />
      </svg>
    )
  }

  {
    tier === 'step' && step === 2 && (
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="24" cy="18" r="8" stroke="currentColor" stroke-width="1.5" />
        <path
          d="M12 38c0-6.627 5.373-12 12-12s12 5.373 12 12"
          stroke="currentColor"
          stroke-width="1.5"
        />
      </svg>
    )
  }

  {
    tier === 'step' && step === 3 && (
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="10" y="14" width="28" height="20" stroke="currentColor" stroke-width="1.5" />
        <line x1="10" y1="20" x2="38" y2="20" stroke="currentColor" stroke-width="1.5" />
        <rect x="16" y="26" width="10" height="4" fill="var(--red)" />
      </svg>
    )
  }

  {
    tier === 'step' && step === 4 && (
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M14 24l6 6 14-14" stroke="var(--red)" stroke-width="2" stroke-linecap="square" />
        <rect x="8" y="8" width="32" height="32" stroke="currentColor" stroke-width="1.5" />
      </svg>
    )
  }
</div>
