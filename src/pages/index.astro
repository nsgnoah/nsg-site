---
import BaseLayout from '../layouts/BaseLayout.astro';
import LabelRow from '../components/LabelRow.astro';
import SectionHead from '../components/SectionHead.astro';
import CtaStrip from '../components/CtaStrip.astro';
import ServiceGlyph from '../components/ServiceGlyph.astro';
import ProofGlyph from '../components/ProofGlyph.astro';

const overview = [
  {
    num: '01',
    name: 'Foundation',
    blurb: 'Custom sites & apps',
    href: '/services#foundation',
    tier: 1
  },
  {
    num: '02',
    name: 'Operations',
    blurb: 'Automation & tools',
    href: '/services#operations',
    tier: 2
  },
  { num: '03', name: 'Intelligence', blurb: 'AI & agents', href: '/services#intelligence', tier: 3 }
];

const picker = [
  {
    quote: 'Our website is embarrassing.',
    tier: 'Foundation',
    tierKey: 1,
    href: '/services#foundation'
  },
  {
    quote: 'We have tons of data but don’t know how to put it to use.',
    tier: 'Operations',
    tierKey: 2,
    href: '/services#operations'
  },
  {
    quote: 'We sometimes spend hours at a time manually formatting Excel and Word documents.',
    tier: 'Operations',
    tierKey: 2,
    href: '/services#operations'
  },
  {
    quote: 'We want to integrate AI but don\u2019t know where to start.',
    tier: 'Intelligence',
    tierKey: 3,
    href: '/services#intelligence'
  },
  {
    quote: 'Wake me up when AI can do something actually useful.',
    tier: 'Intelligence',
    tierKey: 3,
    href: '/services#intelligence'
  }
];

const proof = [
  {
    num: '01',
    tier: 1 as const,
    glyph: 'consolidation' as const,
    sector: 'Start-up reinsurance broker',
    scale: '~10 people',
    built: 'Custom internal web app to automate catastrophe modeling operations',
    before:
      'Every cat modeling run jumped across five tools. Same data re-entered, re-exported, re-checked at each step.',
    after: 'One app for the full cat modeling workflow. Five tools became one system.'
  },
  {
    num: '02',
    tier: 2 as const,
    glyph: 'stage-builder' as const,
    sector: 'Mid-size staging company',
    scale: 'Stage rentals & events',
    built: 'Custom 3D stage builder for quotes and layouts',
    before:
      'Every quote started with hand-drawn stage outlines. Redraw the same rig for each client.',
    after:
      'Drag-and-drop 3D layouts built for how they quote. Sketches became sendable designs the same day.'
  },
  {
    num: '03',
    tier: 3 as const,
    glyph: 'ai-pipeline' as const,
    sector: 'Start-up reinsurance broker',
    scale: '~10 people',
    built: 'AI workflow: raw data in, catastrophe models run, on-brand client reports out',
    before:
      'Cat modeling took a week per run. Manual SQL, then click-through after click-through to finish a model.',
    after:
      'Prep and modeling run automatically. A person still reviews before anything client-facing ships.'
  }
];

const goLinks = [
  {
    num: '01',
    href: '/services',
    title: 'What I build',
    body: 'Three layers, common remarks, and full detail on custom sites, automation, and AI.',
    cta: 'Services'
  },
  {
    num: '02',
    href: '/about',
    title: 'About me',
    body: 'My background, a fit checklist, and how I work day to day.',
    cta: 'About'
  },
  {
    num: '03',
    href: '/contact',
    title: 'Start here',
    body: 'A few sentences on the form is enough. I reply within two business days.',
    cta: 'Contact'
  }
];

const faq = [
  {
    q: 'What does NSG do?',
    a: 'Custom sites, custom apps, automation between tools, and AI wired into real workflows — built for small businesses that don’t have someone in-house to do it.'
  },
  {
    q: 'Do you only do AI?',
    a: 'No. I build custom sites, internal tools, and automation too. AI is part of the work when it saves time on real tasks, not a separate upsell.'
  },
  {
    q: 'How much does it cost?',
    a: 'It depends on the project. I\u2019m happy to grab coffee or hop on a call to hear what\u2019s going on. If we move forward, you\u2019ll get a quote before any work starts.'
  }
];
---

<BaseLayout
  title="NSG Solutions — Sites, software, and AI for small businesses"
  description="Custom sites, custom apps, automation, and AI integration for small businesses in Minneapolis — without an in-house tech team. One person, end to end. Happy to talk for free."
  faq={faq}
>
  <div class="page home-page">
    <div class="container">
      <header class="page-head home-page-head">
        <LabelRow num="NSG / HOME" meta="Minneapolis · Small business" />
        <h1>
          Sites, software, and AI for small businesses<span class="accent">.</span>
        </h1>
        <p class="lede">
          For businesses without an in-house tech team. I handle the technology so you can handle
          everything else.
        </p>
        <div class="home-head-actions">
          <a href="/contact" class="btn btn-primary"
            >Start a conversation <span class="arr">→</span></a
          >
          <a href="/services" class="btn btn-ghost">See what I build</a>
        </div>
        <div class="hero-meta svc-hero-meta">
          <div class="hero-meta-cell">
            <div class="key">Built for</div>
            <div class="val">Small business</div>
          </div>
          <div class="hero-meta-cell">
            <div class="key">Based in</div>
            <div class="val">Minneapolis, MN</div>
          </div>
          <div class="hero-meta-cell">
            <div class="key">Talking</div>
            <div class="val">Always free</div>
          </div>
        </div>
      </header>
    </div>

    <div class="home-intro-band">
      <div class="container">
        <div class="svc-overview" aria-label="Three service areas">
          {
            overview.map((item) => (
              <a class:list={['svc-overview-card', `svc-overview-${item.tier}`]} href={item.href}>
                <div class="svc-overview-glyph">
                  <ServiceGlyph tier={item.tier as 1 | 2 | 3} />
                </div>
                <div class="svc-overview-text">
                  <span class="svc-overview-num">{item.num}</span>
                  <span class="svc-overview-name">{item.name}</span>
                  <span class="svc-overview-blurb">{item.blurb}</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <section class="section svc-picker-section home-picker-section">
      <div class="container">
        <SectionHead num="01 / START HERE" meta="Which sounds like you?">
          <Fragment slot="title">Pick the line that matches.</Fragment>
        </SectionHead>

        <div class="svc-picker" role="list">
          {
            picker.map((row) => (
              <a
                class:list={['svc-picker-row', `picker-tier-${row.tierKey}`]}
                href={row.href}
                role="listitem"
              >
                <span class="svc-picker-dot" aria-hidden="true" />
                <span class="svc-picker-quote">&ldquo;{row.quote}&rdquo;</span>
                <span class="svc-picker-arrow" aria-hidden="true">
                  &rarr;
                </span>
                <span class="svc-picker-tier">{row.tier}</span>
              </a>
            ))
          }
        </div>

        <p class="home-section-more">
          Full picker and tier detail on <a href="/services">services</a>.
        </p>
      </div>
    </section>

    <section class="section home-proof-section">
      <div class="container">
        <SectionHead num="02 / PROOF" meta="Previous work">
          <Fragment slot="title">Work that shipped.</Fragment>
        </SectionHead>

        <div class="home-proof-list">
          {
            proof.map((item) => (
              <article class:list={['home-proof-item', `home-proof-tier-${item.tier}`]}>
                <div class:list={['home-proof-frame', `svc-tier-${item.tier}`]}>
                  <div class="home-proof-visual">
                    <span class="home-proof-num">{item.num}</span>
                    <div class="home-proof-glyph">
                      <ProofGlyph variant={item.glyph} />
                    </div>
                    <p class="home-proof-visual-label">
                      {item.sector}
                      <span>{item.scale}</span>
                    </p>
                  </div>
                  <div class="svc-tier-body home-proof-body">
                    <dl class="home-proof-facts">
                      <div class="home-proof-fact">
                        <dt>Built</dt>
                        <dd class="home-proof-built">{item.built}</dd>
                      </div>
                      <div class="home-proof-fact">
                        <dt>Before</dt>
                        <dd>{item.before}</dd>
                      </div>
                      <div class="home-proof-fact">
                        <dt>After</dt>
                        <dd>{item.after}</dd>
                      </div>
                    </dl>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section svc-stack-section">
      <div class="container">
        <SectionHead num="03 / THE STACK" meta="How it fits together">
          <Fragment slot="title">AI works two ways.</Fragment>
        </SectionHead>

        <div class="svc-stack-wrap">
          <div class="svc-stack-viz" aria-hidden="true">
            <div class="stack-block stack-block-intel">
              <span class="stack-block-num">03</span>
              <span class="stack-block-name">Intelligence</span>
              <span class="stack-block-note">Agents &middot; MCP &middot; skills</span>
            </div>
            <div class="svc-stack-base">
              <div class="svc-stack-layers">
                <div class="stack-block stack-block-2">
                  <span class="stack-block-num">02</span>
                  <span class="stack-block-name">Operations</span>
                  <span class="stack-block-note"
                    >Marketing &middot; dashboards &middot; reports</span
                  >
                </div>
                <div class="stack-block stack-block-1">
                  <span class="stack-block-num">01</span>
                  <span class="stack-block-name">Foundation</span>
                  <span class="stack-block-note">Sites &middot; apps &middot; portals</span>
                </div>
              </div>
              <div class="svc-stack-spine">
                <span class="svc-stack-spine-stack">
                  <span class="svc-stack-spine-label">AI</span>
                  <span class="svc-stack-spine-note">Fast &middot; cheap &middot; automation</span>
                </span>
              </div>
            </div>
          </div>

          <div class="svc-stack-copy">
            <p>
              AI runs through what you already do &mdash; building the site, inside the apps,
              augmenting how you operate &mdash; and it&rsquo;s a craft of its own: custom agents,
              MCP servers, and skills. I manage all of it so the layers connect.
            </p>
            <p class="home-section-more home-section-more--inline">
              <a href="/services#the-stack">Read more about the stack &rarr;</a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section home-go-section">
      <div class="container">
        <SectionHead num="04 / GO DEEPER" meta="The rest of the site">
          <Fragment slot="title">Where to go next.</Fragment>
        </SectionHead>

        <div class="home-go-grid">
          {
            goLinks.map((link, i) => (
              <a href={link.href} class:list={['home-go-card', `home-go-card-${i + 1}`]}>
                <span class="home-go-num">{link.num}</span>
                <h3>{link.title}</h3>
                <p>{link.body}</p>
                <span class="home-go-cta">
                  {link.cta} <span aria-hidden="true">&rarr;</span>
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section home-faq-section">
      <div class="container">
        <SectionHead num="05 / FAQ" meta="Quick answers">
          <Fragment slot="title">Before you write.</Fragment>
        </SectionHead>

        <dl class="about-faq">
          {
            faq.map((item) => (
              <div class="about-faq-item">
                <dt>{item.q}</dt>
                <dd>{item.a}</dd>
              </div>
            ))
          }
        </dl>

        <p class="home-section-more">
          Fit checklist, process, and more Q&amp;A on <a href="/about">about</a>.
        </p>
      </div>
    </section>

    <CtaStrip
      title="Have any questions?"
      answer="Not sure where to start? That’s fine."
      note="Reply within two business days · I’ll tell you if it’s not"
      primaryText="Start a conversation"
      ghostText="Email directly"
    />
  </div>
</BaseLayout>
