---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHead from '../components/SectionHead.astro';
import LabelRow from '../components/LabelRow.astro';
import WorkCard from '../components/WorkCard.astro';
import CtaStrip from '../components/CtaStrip.astro';

// Problem cards grouped into the three tiers of the modernization stack.
// Foundation (basics) → Operations (the slow parts) → Intelligence (AI fits).
const tiers = [
  {
    key: 'foundation',
    num: '01',
    name: 'Foundation',
    heading: 'The basics, working.',
    items: [
      ['01', '"Our website looks like every other shop on the block."', "A site that's actually yours. Fast, tailored, built to last."],
      ['02', '"The thing we need doesn\u2019t exist off the shelf."', 'Built around how you actually work, no extra features in the way.']
    ]
  },
  {
    key: 'operations',
    num: '02',
    name: 'Operations',
    heading: 'The slow parts, fixed.',
    items: [
      ['03', '"There\u2019s a spreadsheet four people maintain and nobody trusts."', 'Replaced with a small internal app. Single source of truth, no copy-paste.'],
      ['04', '"Three tools don\u2019t talk to each other; we re-enter everything."', 'Wired together. The same data only gets typed once.']
    ]
  },
  {
    key: 'intelligence',
    num: '03',
    name: 'Intelligence',
    heading: 'AI, where it actually fits.',
    items: [
      ['05', '"Every Monday morning is the same hour of busywork."', 'A scheduled job, with an AI step where judgment is needed. Done before anyone clocks in.'],
      ['06', '"We want to use AI but don\u2019t know where it fits."', 'Pick the right shape for your operation. Build it in. Audit trail, human checkpoints where it matters.']
    ]
  }
];

const principles = [
  ['01 / DIRECT', 'One person, start to finish.', 'You describe the problem to the same person who builds and ships the fix. Nothing translated, nothing lost on a handoff.'],
  ['02 / HONEST', 'Done means done.', 'Work continues until you look at it and say "this is better than what we had in mind." If something later breaks that we agreed was finished, fixing it is free.'],
  ['03 / HANDS-ON', 'Visible while it\u2019s built.', 'You see the work as it\u2019s built, not in a reveal at the end. In person where possible, video the rest of the time.']
];

const work = [
  {
    kind: 'Web · Custom CMS',
    industry: 'Specialty retail',
    year: '2026',
    title: 'A storefront site that doesn\u2019t look like a template.',
    desc: 'New website and ordering flow for a dispensary opening in St. Paul. Fast, tailored, and easy for staff to update without calling anyone.',
    tag: 'STOREFRONT_001.JPG'
  },
  {
    kind: 'Custom tool · 3D',
    industry: 'Event staging',
    year: '2026',
    title: 'Stage builder, in 3D, before anything is built.',
    desc: 'Internal 3D visualizer that lets a staging company see a stage in a venue before the trucks roll out. Replacing a stack of PDFs and best-guesses.',
    tag: 'STAGE_PREVIEW.GLB'
  },
  {
    kind: 'Web · Forms',
    industry: 'University research',
    year: '2024',
    title: 'A grant-application tool that researchers will actually use.',
    desc: 'Custom application portal for environmental grant submissions at the University of Minnesota. Replaced a tangle of forms and email threads.',
    tag: 'GRANTS_PORTAL.PNG'
  },
  {
    kind: 'Automation · AI',
    industry: 'Reinsurance',
    year: 'Ongoing',
    title: 'Catastrophe-modeling, on a schedule.',
    desc: "Automation layer over a broker's catastrophe-modeling pipeline. The same numbers, an order of magnitude faster, with eyes on every step that matters.",
    tag: 'CAT_MODEL.RUN'
  }
];
---

<BaseLayout
  title="NSG Solutions — Modern software for small businesses in Minneapolis"
  description="Modern websites, internal tools, automation, and AI integration for small businesses. One person, end-to-end. Based in Minneapolis, MN."
>
  <div class="page home-page">
    <section class="hero">
      <div class="container">
        <div class="hero-meta">
          <div class="hero-meta-cell">
            <div class="key">Practice</div>
            <div class="val">Custom software</div>
          </div>
          <div class="hero-meta-cell">
            <div class="key">Based in</div>
            <div class="val">Minneapolis, MN</div>
          </div>
          <div class="hero-meta-cell">
            <div class="key">Working with</div>
            <div class="val">Small businesses</div>
          </div>
        </div>

        <h1 class="hero-title">
          Software for where your<br />
          business is, and where<br />
          <span class="hero-final-line">it&rsquo;s <span class="already">headed next</span><span class="accent">.</span></span>
        </h1>

        <div class="hero-sub">
          <p>
            The website that loads fast and looks like it belongs to your business. The spreadsheet
            replaced with something you can trust. The Monday morning task,
            automated before anyone clocks in. And when the foundation&rsquo;s
            solid, the AI layer that actually earns its place.
          </p>
          <div class="hero-actions">
            <a href="/contact" class="btn btn-primary">Start a conversation <span class="arr">→</span></a>
            <a href="/services" class="btn btn-ghost">What we do</a>
          </div>
        </div>

        <div class="ticker">
          <span><span class="dot"></span>Currently taking on 1–2 new engagements</span>
          <span>· Replies within two business days</span>
          <span>· In person when possible</span>
        </div>
      </div>
    </section>

    <section class="section problems">
      <div class="container">
        <SectionHead num="01 / WHY HIRE" meta="The work">
          <Fragment slot="title">Things that get in the way<br /><em>of getting work done.</em></Fragment>
        </SectionHead>

        {tiers.map((tier) => (
          <div class:list={['tier-group', `tier-${tier.num.replace(/^0/, '')}`]}>
            <div class:list={['tier-intro', `tier-${tier.num.replace(/^0/, '')}`]}>
              <div class="ti-num"><em>TIER {tier.num}</em> · {tier.name.toUpperCase()}</div>
              <h3>{tier.heading}</h3>
            </div>
            <div class="problems-list">
              {tier.items.map(([num, quote, fix]) => (
                <div class="problem">
                  <span class="num">PROBLEM / {num}</span>
                  <div class="problem-quote">{quote}</div>
                  <div class="problem-fix">
                    <span class="arrow">→</span>
                    <span>{fix}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="section approach">
      <div class="container">
        <LabelRow num="02 / APPROACH" meta="How NSG works" />

        <div class="principle-grid">
          {principles.map(([num, title, body]) => (
            <div class="principle">
              <span class="marker"></span>
              <span class="num">{num}</span>
              <h3>{title}</h3>
              <p>{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section work">
      <div class="container">
        <SectionHead num="03 / SELECTED WORK" meta="Recent engagements">
          <Fragment slot="title"><span class="work-title-oneline">A few things currently in flight.</span></Fragment>
        </SectionHead>

        <div class="work-list">
          {work.map((item, index) => <WorkCard index={index} {...item} />)}
        </div>
      </div>
    </section>

    <section class="section manifesto">
      <div class="container">
        <LabelRow num="04 / NOTE" meta="From the workbench" dark />
        <h2>
          The work isn&rsquo;t done until you look at it and say:<br />
          <em class="manifesto-tail">&ldquo;this is better than what we had in mind.&rdquo;</em>
        </h2>
      </div>
    </section>

    <CtaStrip
      title="Have a small thorn<br/>in your operation?"
      continuation="Send a note."
      note="Replies within two business days · No commitment until you&rsquo;re ready"
      primaryText="Get in touch"
      ghostText="Email directly"
    />
  </div>
</BaseLayout>

<style is:global>
  .approach-heading-keep {
    white-space: nowrap;
  }
</style>
