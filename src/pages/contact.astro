---
import BaseLayout from '../layouts/BaseLayout.astro';
import LabelRow from '../components/LabelRow.astro';

const types = ['Automation', 'Custom tool', 'AI integration', 'Connecting tools', 'Not sure yet'];
---

<BaseLayout
  title="Contact — NSG Solutions"
  description="Start a conversation with NSG Solutions. A few sentences about what's in the way is plenty — replies within two business days, from Noah."
>
  <div class="page">
    <div class="container">
      <header class="page-head">
        <LabelRow num="CONTACT / 01" meta="Start a conversation" />
        <h1>Say hi.<br /><em>Describe what's in the way.</em></h1>
        <p class="lede">
          A few sentences is plenty. You'll hear back from me within two business days.
        </p>
      </header>

      <section class="contact-layout">
        <div id="contact-success" class="contact-success" hidden>
          <LabelRow num="SENT" />
          <h2>Got it. <em>Talk soon.</em></h2>
          <p>
            You'll hear back from me within two business days. If something's urgent, email
            <a href="mailto:noah@nsgsolutions.co">noah@nsgsolutions.co</a> directly.
          </p>
        </div>

        <noscript>
          <p style="padding: 1rem; border: 1px solid var(--gray-200); margin-bottom: 1rem;">
            This form needs JavaScript to send. If you have it disabled, email
            <a href="mailto:noah@nsgsolutions.co">noah@nsgsolutions.co</a> directly.
          </p>
        </noscript>

        <form id="contact-form" class="contact-form">
          <div class="field">
            <label for="name">Your name</label>
            <input id="name" name="name" type="text" required placeholder="Jane Smith" autocomplete="name" />
            <p id="error-name" style="display: none; color: var(--red); font-size: 0.8rem; margin-top: 0.25rem;"></p>
          </div>

          <div class="field">
            <label for="email">Email</label>
            <input id="email" name="email" type="email" required placeholder="jane@yourbusiness.com" autocomplete="email" />
            <p id="error-email" style="display: none; color: var(--red); font-size: 0.8rem; margin-top: 0.25rem;"></p>
          </div>

          <div class="field">
            <label>What kind of work? <span style="font-weight: 400; color: var(--gray-300);">(optional)</span></label>
            <div class="chips" role="listbox" aria-label="What kind of work?">
              {types.map((type) => (
                <button class="chip" type="button" data-value={type} role="option" aria-selected="false">{type}</button>
              ))}
            </div>
            <input id="type-input" name="type" type="hidden" />
          </div>

          <div class="field">
            <label for="message">What's going on?</label>
            <textarea id="message" name="message" required rows="6" placeholder="A few sentences is plenty. What's in the way? What does &quot;done&quot; look like?"></textarea>
            <p id="error-message" style="display: none; color: var(--red); font-size: 0.8rem; margin-top: 0.25rem;"></p>
          </div>

          <p id="submit-error" style="display: none; color: var(--red); font-size: 0.9rem;"></p>

          <button type="submit" class="btn btn-primary" style="align-self: flex-start;">
            Send the note <span class="arr">→</span>
          </button>
        </form>

        <aside class="contact-aside">
          <div class="block">
            <h3>Direct line</h3>
            <p><a href="mailto:noah@nsgsolutions.co">noah@nsgsolutions.co</a></p>
          </div>
          <div class="block">
            <h3>Reply time</h3>
            <p>Within two business days. If timing is tight, say so in the note.</p>
          </div>
          <div class="block">
            <h3>What happens next</h3>
            <p>We'll set up a call — in person if you're in Minneapolis. We talk through what you're dealing with, then you get a plain-language proposal: scope, timeline, price. No commitment until you're ready.</p>
          </div>
          <div class="block">
            <h3>Where</h3>
            <p>Minneapolis, MN. Available remote everywhere else.</p>
          </div>
        </aside>
      </section>
    </div>
  </div>

  <script>
    const FORMSPREE_ID = 'xlgwzyop';
    const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    const form = document.getElementById('contact-form');
    const successDiv = document.getElementById('contact-success');
    const typeInput = document.getElementById('type-input');
    const chips = document.querySelectorAll('.chip');
    const submitBtn = form.querySelector('button[type="submit"]');
    const submitError = document.getElementById('submit-error');

    function clearError(fieldName) {
      const errorEl = document.getElementById(`error-${fieldName}`);
      if (errorEl) {
        errorEl.style.display = 'none';
        errorEl.textContent = '';
      }
    }

    function showError(fieldName, message) {
      const errorEl = document.getElementById(`error-${fieldName}`);
      if (errorEl) {
        errorEl.textContent = message;
        errorEl.style.display = 'block';
      }
    }

    function validate() {
      const errors = {};
      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const message = document.getElementById('message').value.trim();

      if (!name) {
        errors.name = "Add your name so I know who I'm talking to.";
      }
      if (!email) {
        errors.email = "That email doesn't look right.";
      } else if (!EMAIL_REGEX.test(email)) {
        errors.email = "That email doesn't look right.";
      }
      if (!message) {
        errors.message = "Add a short note so I know what this is about.";
      }

      return errors;
    }

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const value = chip.getAttribute('data-value') || '';
        const isActive = chip.classList.contains('active');

        chips.forEach((c) => {
          c.classList.remove('active');
          c.setAttribute('aria-selected', 'false');
        });

        typeInput.value = isActive ? '' : value;

        if (!isActive) {
          chip.classList.add('active');
          chip.setAttribute('aria-selected', 'true');
        }
      });
    });

    document.getElementById('name').addEventListener('blur', () => {
      const errors = validate();
      if (errors.name) {
        showError('name', errors.name);
      } else {
        clearError('name');
      }
    });

    document.getElementById('name').addEventListener('input', () => {
      clearError('name');
    });

    document.getElementById('email').addEventListener('blur', () => {
      const errors = validate();
      if (errors.email) {
        showError('email', errors.email);
      } else {
        clearError('email');
      }
    });

    document.getElementById('email').addEventListener('input', () => {
      clearError('email');
    });

    document.getElementById('message').addEventListener('blur', () => {
      const errors = validate();
      if (errors.message) {
        showError('message', errors.message);
      } else {
        clearError('message');
      }
    });

    document.getElementById('message').addEventListener('input', () => {
      clearError('message');
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      const errors = validate();
      if (Object.keys(errors).length > 0) {
        Object.entries(errors).forEach(([field, message]) => {
          showError(field, message);
        });
        return;
      }

      submitBtn.setAttribute('disabled', '');
      submitError.style.display = 'none';

      try {
        const response = await fetch(`https://formspree.io/f/${FORMSPREE_ID}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: document.getElementById('name').value,
            email: document.getElementById('email').value,
            type: typeInput.value,
            message: document.getElementById('message').value,
          }),
        });

        if (!response.ok) {
          throw new Error('Submission failed');
        }

        form.style.display = 'none';
        successDiv?.removeAttribute('hidden');
        successDiv?.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      } catch {
        submitBtn.removeAttribute('disabled');
        submitError.textContent = 'Something broke. Try again, or email noah@nsgsolutions.co directly.';
        submitError.style.display = 'block';
      }
    });
  </script>
</BaseLayout>
