---
import BaseLayout from '../layouts/BaseLayout.astro';
import LabelRow from '../components/LabelRow.astro';
import ServiceGlyph from '../components/ServiceGlyph.astro';

const types = ['A site or app', 'Automation', 'AI', 'Not sure yet'];

const nextSteps = [
  {
    num: '01',
    title: 'Send the note',
    body: 'A few sentences is enough. What you\u2019re looking for, and what \u201cdone\u201d looks like.'
  },
  {
    num: '02',
    title: 'Hear back within two business days',
    body: 'By email or phone, whichever you pick on the form.'
  },
  {
    num: '03',
    title: 'A call to talk it through',
    body: 'Talking is always free. I\u2019ll be honest about whether it\u2019s a fit, and I\u2019ll send over a plain quote once we know the shape.'
  }
];

const defaultFormEndpoint = 'https://formspree.io/f/xlgwzyop';
const contactFormEndpoint =
  import.meta.env.PUBLIC_CONTACT_FORM_ENDPOINT?.trim() || defaultFormEndpoint;
---

<BaseLayout
  title="Contact — Start a conversation | NSG Solutions"
  description="Contact NSG Solutions in Minneapolis. Describe what you need. Reply within two business days from Noah."
  breadcrumb={[
    { name: 'Home', href: '/' },
    { name: 'Contact', href: '/contact' }
  ]}
>
  <div class="page contact-page">
    <div class="container">
      <header class="page-head contact-page-head">
        <LabelRow num="CONTACT / 01" meta="Start a conversation" />
        <h1>
          Let&rsquo;s figure it out together<span class="accent">.</span>
        </h1>
        <p class="lede">
          Reach out and you get me, not a sales team. Whether you know exactly what you need or just
          have a rough idea, a short note on the form is enough to get started. Or we can set up a
          call, whatever&rsquo;s easier.
        </p>
        <div class="hero-meta contact-hero-meta">
          <div class="hero-meta-cell">
            <div class="key">Reply</div>
            <div class="val">&le; 2 business days</div>
          </div>
          <div class="hero-meta-cell">
            <div class="key">Based in</div>
            <div class="val">Minneapolis, MN</div>
          </div>
          <div class="hero-meta-cell">
            <div class="key">Email</div>
            <div class="val">
              <a href="mailto:noah@nsgsolutions.co">noah@nsgsolutions.co</a>
            </div>
          </div>
        </div>
      </header>
    </div>

    <section class="section contact-main-section">
      <div class="container">
        <div class="contact-frame">
          <div class="contact-form-col">
            <LabelRow num="FORM / 02" meta="Send a note" />

            <div id="contact-success" class="contact-success" hidden>
              <LabelRow num="SENT" meta="On its way" />
              <h2>Got it. <em>Talk soon.</em></h2>
              <p>
                You&rsquo;ll hear back within two business days. If something&rsquo;s urgent, email
                <a href="mailto:noah@nsgsolutions.co">noah@nsgsolutions.co</a> directly.
              </p>
            </div>

            <noscript>
              <p class="contact-noscript">
                This form needs JavaScript to send. If you have it disabled, email
                <a href="mailto:noah@nsgsolutions.co">noah@nsgsolutions.co</a> directly.
              </p>
            </noscript>

            <form id="contact-form" class="contact-form" novalidate>
              <div class="field">
                <label for="name">Your name</label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  required
                  placeholder="Jane Smith"
                  autocomplete="name"
                />
                <p id="error-name" class="field-error" hidden></p>
              </div>

              <div class="field">
                <label for="email">Email</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  placeholder="jane@yourbusiness.com"
                  autocomplete="email"
                />
                <p id="error-email" class="field-error" hidden></p>
              </div>

              <div class="field">
                <label for="phone">Phone <span class="chips-optional">(optional)</span></label>
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  placeholder="(612) 555-0123"
                  autocomplete="tel"
                />
              </div>

              <div class="field">
                <fieldset class="chips-fieldset">
                  <legend class="chips-legend">Preferred contact</legend>
                  <div class="chips">
                    <label class="chip-label">
                      <input
                        class="chip-input chip-contact"
                        type="radio"
                        name="contact-method"
                        value="Email"
                        required
                      />
                      <span class="chip">Email</span>
                    </label>
                    <label class="chip-label">
                      <input
                        class="chip-input chip-contact"
                        type="radio"
                        name="contact-method"
                        value="Phone call"
                        required
                      />
                      <span class="chip">Phone call</span>
                    </label>
                  </div>
                </fieldset>
                <input id="contact-method-input" name="contact_method" type="hidden" />
                <p id="error-contact-method" class="field-error" hidden></p>
              </div>

              <div class="field">
                <fieldset class="chips-fieldset">
                  <legend class="chips-legend">
                    Starting point <span class="chips-optional">(optional)</span>
                  </legend>
                  <div class="chips">
                    {
                      types.map((type) => (
                        <label class="chip-label">
                          <input class="chip-input" type="checkbox" value={type} />
                          <span class="chip">{type}</span>
                        </label>
                      ))
                    }
                  </div>
                </fieldset>
                <input id="type-input" name="type" type="hidden" />
              </div>

              <div class="field">
                <label for="message">What&rsquo;s going on?</label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="6"
                  placeholder="What do you need built? What might done look like? A few sentences is plenty."
                ></textarea>
                <p id="error-message" class="field-error" hidden></p>
              </div>

              <p id="submit-error" class="field-error field-error--submit" hidden></p>

              <button type="submit" class="btn btn-primary contact-submit">
                Send the note <span class="arr">→</span>
              </button>
            </form>
          </div>

          <aside class="contact-aside contact-aside-panel" aria-label="What happens after you send">
            <div class="contact-aside-block contact-aside-direct">
              <span class="contact-aside-label">Direct line</span>
              <p>
                <a href="mailto:noah@nsgsolutions.co">noah@nsgsolutions.co</a>
              </p>
            </div>

            <div class="contact-aside-block">
              <span class="contact-aside-label">What happens next</span>
              <ol class="contact-steps">
                {
                  nextSteps.map((step, i) => (
                    <li class="contact-step">
                      <div class="contact-step-icon" aria-hidden="true">
                        <ServiceGlyph tier="step" step={i + 1} />
                      </div>
                      <div class="contact-step-body">
                        <span class="contact-step-num">{step.num}</span>
                        <h3>{step.title}</h3>
                        <p>{step.body}</p>
                      </div>
                    </li>
                  ))
                }
              </ol>
            </div>

            <p class="contact-section-more">
              Good-fit checklist on <a href="/about#good-fit">about</a>. Full build process on
              <a href="/services">services</a>.
            </p>
          </aside>
        </div>
      </div>
    </section>
  </div>

  <script define:vars={{ contactFormEndpoint }}>
    const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    const form = document.getElementById('contact-form');
    const successDiv = document.getElementById('contact-success');
    const typeInput = document.getElementById('type-input');
    const contactMethodInput = document.getElementById('contact-method-input');
    const chipInputs = document.querySelectorAll('.chip-input:not(.chip-contact)');
    const contactMethodRadios = document.querySelectorAll('.chip-contact');
    const submitBtn = form?.querySelector('button[type="submit"]');
    const submitError = document.getElementById('submit-error');
    const nameInput = document.getElementById('name');
    const emailInput = document.getElementById('email');
    const phoneInput = document.getElementById('phone');
    const messageInput = document.getElementById('message');

    if (
      !form ||
      !typeInput ||
      !contactMethodInput ||
      !submitBtn ||
      !submitError ||
      !nameInput ||
      !emailInput ||
      !messageInput
    ) {
      // Form markup changed or script running on wrong page; skip setup.
    } else {
      function syncTypeFromChips() {
        typeInput.value = [...chipInputs]
          .filter((i) => i.checked)
          .map((i) => i.value)
          .join(', ');
      }

      function syncContactMethod() {
        const selected = [...contactMethodRadios].find((i) => i.checked);
        contactMethodInput.value = selected?.value ?? '';
      }

      function clearError(fieldName) {
        const errorEl = document.getElementById(`error-${fieldName}`);
        if (errorEl) {
          errorEl.hidden = true;
          errorEl.textContent = '';
        }
      }

      function showError(fieldName, message) {
        const errorEl = document.getElementById(`error-${fieldName}`);
        if (errorEl) {
          errorEl.textContent = message;
          errorEl.hidden = false;
        }
      }

      function validate() {
        const errors = {};
        const name = nameInput.value.trim();
        const email = emailInput.value.trim();
        const message = messageInput.value.trim();
        const contactMethod = [...contactMethodRadios].find((i) => i.checked);

        if (!name) {
          errors.name = "Add your name so I know who I'm talking to.";
        }
        if (!email) {
          errors.email = "That email doesn't look right.";
        } else if (!EMAIL_REGEX.test(email)) {
          errors.email = "That email doesn't look right.";
        }
        if (!contactMethod) {
          errors['contact-method'] = 'Please select a preferred contact method.';
        }
        if (!message) {
          errors.message = 'Add a short note so I know what this is about.';
        }

        return errors;
      }

      chipInputs.forEach((input) => input.addEventListener('change', syncTypeFromChips));
      contactMethodRadios.forEach((input) =>
        input.addEventListener('change', () => {
          syncContactMethod();
          clearError('contact-method');
        })
      );

      nameInput.addEventListener('blur', () => {
        const errors = validate();
        if (errors.name) {
          showError('name', errors.name);
        } else {
          clearError('name');
        }
      });

      nameInput.addEventListener('input', () => {
        clearError('name');
      });

      emailInput.addEventListener('blur', () => {
        const errors = validate();
        if (errors.email) {
          showError('email', errors.email);
        } else {
          clearError('email');
        }
      });

      emailInput.addEventListener('input', () => {
        clearError('email');
      });

      messageInput.addEventListener('blur', () => {
        const errors = validate();
        if (errors.message) {
          showError('message', errors.message);
        } else {
          clearError('message');
        }
      });

      messageInput.addEventListener('input', () => {
        clearError('message');
      });

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const errors = validate();
        if (Object.keys(errors).length > 0) {
          Object.entries(errors).forEach(([field, message]) => {
            showError(field, message);
          });
          return;
        }

        submitBtn.setAttribute('disabled', '');
        submitError.hidden = true;

        try {
          const response = await fetch(contactFormEndpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify({
              name: nameInput.value,
              email: emailInput.value,
              phone: phoneInput?.value || '',
              contact_method: contactMethodInput.value,
              type: typeInput.value,
              message: messageInput.value
            })
          });

          if (!response.ok) {
            throw new Error('Submission failed');
          }

          form.style.display = 'none';
          successDiv?.removeAttribute('hidden');
          successDiv?.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        } catch {
          submitBtn.removeAttribute('disabled');
          submitError.textContent =
            'Something broke. Try again, or email noah@nsgsolutions.co directly.';
          submitError.hidden = false;
        }
      });
    }
  </script>
</BaseLayout>
