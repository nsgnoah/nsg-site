---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import LabelRow from '../components/LabelRow.astro';
import SectionHead from '../components/SectionHead.astro';
import CtaStrip from '../components/CtaStrip.astro';
import noahPhoto from '../assets/noah.jpg';

const logistics = [
  ['Based in', 'Minneapolis, MN'],
  ['Practice', 'Custom sites \u00b7 Tools \u00b7 AI'],
  ['Reply time', '\u2264 2 business days']
];

const plainEnglish = [
  {
    num: '01 / WHAT I DO',
    title: 'Custom sites, internal tools, automations, and AI that does real work.',
    body: 'Custom sites, spreadsheet replacements, and AI wired into the workflows you already run.',
    detail: 'Agents, tool integrations, and custom AI workflows built around how you operate.'
  },
  {
    num: '02 / HOW WE COLLABORATE',
    title: 'We scope it together. I build it. You see it as it comes together.',
    body: 'A live preview and regular check-ins, so we course-correct along the way \u2014 not a big reveal at the end.',
    detail: 'In person as often as is helpful.'
  },
  {
    num: '03 / WHAT YOU GET',
    title: 'Production software, maintained.',
    body: 'Work continues until it fits your work. If agreed finished work breaks later, fixing it is free. And I stick around to maintain and grow it as your needs change.',
    detail: 'You own it. I can keep running it for you, or another developer can pick it up later.'
  }
];

const goodFit = [
  '\u201cWe don\u2019t have an IT person or a developer, and we\u2019re not going to hire one.\u201d',
  '\u201cWe want AI integrated into how we actually work, not another subscription nobody uses.\u201d',
  '\u201cOur website is embarrassing and we\u2019re a real business.\u201d',
  '\u201cWe\u2019re running the company on shared spreadsheets.\u201d',
  '\u201cWe want software live, not a strategy meeting.\u201d',
  '\u201cOne person can make decisions without a committee.\u201d'
];

const notFit = [
  '\u201cWe need a developer to staff a team for a few months.\u201d',
  '\u201cWe want an AI strategy deck, with the building left to someone else.\u201d',
  '\u201cOur plan is \u2018AI everywhere\u2019 with no one owning the process.\u201d',
  '\u201cThe people who\u2019d use the tool aren\u2019t part of the conversation.\u201d'
];

const faq = [
  {
    q: 'Do you do AI work?',
    a: 'Yes. Picking the right tools, wiring them into your software, and building custom agents and workflows. I work with AI every day and stay on top of how fast it’s moving.'
  },
  {
    q: 'Who will I be working with?',
    a: 'Me, directly — the person designing and building your project. I may bring in a specialist for something narrow, but you stay with me start to finish. I’m easy to reach and quick to respond.'
  },
  {
    q: 'Do you bill on an hourly or project basis?',
    a: 'Usually hourly, so you only pay for the work that happens. When a project has a clear, well-defined scope, a fixed price can make more sense, and I\u2019ll suggest that instead. Either way, we agree on it up front, and talking is always free.'
  },
  {
    q: 'Where are you located?',
    a: 'Minneapolis, working with partners across the metro and around the state. I care about real relationships, so I’m happy to meet in person whenever that’s helpful.'
  }
];
---

<BaseLayout
  title="About — Noah Greensweig | Minneapolis Software & AI Consultant | NSG Solutions"
  description="Noah Greensweig runs NSG Solutions, a one-person software and AI practice in Minneapolis. Custom sites, tools, automations, and AI integration. End to end, no handoffs."
  breadcrumb={[
    { name: 'Home', href: '/' },
    { name: 'About', href: '/about' }
  ]}
  faq={faq}
>
  <div class="page about-page">
    <div class="container">
      <section class="about-hero">
        <div class="about-hero-copy">
          <LabelRow num="ABOUT / 01" meta="Who runs NSG" />
          <h1>I'm Noah.<br /><em>I build software and AI for small businesses.</em></h1>
          <p class="lede">
            NSG is a Minneapolis practice for small businesses that don&rsquo;t have a full-time
            developer or IT team on staff &mdash; and don&rsquo;t need one. We figure out what you
            need together, and I build it: custom sites, internal tools, automations, and AI wired
            into how you work.
          </p>
          <div class="hero-meta about-logistics">
            {
              logistics.map(([key, val]) => (
                <div class="hero-meta-cell">
                  <div class="key">{key}</div>
                  <div class="val">{val}</div>
                </div>
              ))
            }
          </div>
        </div>
        <div class="about-photo-frame">
          <Image
            src={noahPhoto}
            alt="Noah Greensweig, founder of NSG Solutions"
            width={800}
            height={800}
            format="avif"
            quality={70}
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <div class="about-photo-tag">
            <span class="dash"></span>Noah Greensweig &middot; Minneapolis, MN
          </div>
        </div>
      </section>
    </div>

    <section class="section about-plain-section">
      <div class="container">
        <SectionHead num="02 / OVERVIEW" meta="The essentials">
          <Fragment slot="title">What I do, how we collaborate, what you get.</Fragment>
        </SectionHead>

        <div class="principle-grid about-principle-grid">
          {
            plainEnglish.map((item) => (
              <div class="principle">
                <span class="marker" />
                <span class="num">{item.num}</span>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
                <p class="principle-detail">{item.detail}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section about-background-section">
      <div class="container">
        <SectionHead num="03 / BACKGROUND" meta="Where NSG comes from">
          <Fragment slot="title">Where NSG comes from.</Fragment>
        </SectionHead>

        <div class="about-prose about-prose-solo">
          <div class="body-col">
            <p>
              For six years I&apos;ve built software to automate the work that eats people&apos;s
              weeks at non-profits, large universities, and financial services companies. The kind
              of recurring, manual work that used to take hours.
            </p>
            <p>
              AI changed what&apos;s possible. Custom agents, tool integrations, and workflows can
              now do that work reliably, end to end. NSG is where I bring it to small companies:
              pick the right tools, wire them into how you already work, and build something that
              sticks.
            </p>
            <p class="about-ai-note">
              <strong>On AI:</strong> I build it, not just advise on it. I&apos;ll tell you straight when
              something isn&apos;t ready yet, but AI is core to what I do.
              <a href="/services#intelligence">See AI work in detail &rarr;</a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section about-fit-section" id="good-fit">
      <div class="container">
        <SectionHead num="04 / GOOD FIT" meta="Is this a match?">
          <Fragment slot="title">Are we a good fit?</Fragment>
        </SectionHead>

        <div class="about-fit-grid">
          <div class="about-fit-col about-fit-yes">
            <h3 class="about-fit-heading">Good fit</h3>
            <ul class="about-fit-list">
              {
                goodFit.map((item) => (
                  <li>
                    <span class="fit-mark fit-yes" aria-hidden="true" />
                    <p>{item}</p>
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="about-fit-col about-fit-no">
            <h3 class="about-fit-heading">Probably not a fit</h3>
            <ul class="about-fit-list">
              {
                notFit.map((item) => (
                  <li>
                    <span class="fit-mark fit-no" aria-hidden="true" />
                    <p>{item}</p>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="section about-faq-section">
      <div class="container">
        <SectionHead num="05 / FAQ" meta="Common questions">
          <Fragment slot="title">Frequently asked questions</Fragment>
        </SectionHead>

        <dl class="about-faq">
          {
            faq.map((item) => (
              <div class="about-faq-item">
                <dt>{item.q}</dt>
                <dd>{item.a}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <CtaStrip
      title="Have any questions?"
      answer="Not sure where to start? That’s fine."
      note="Two business-day reply · No commitment until you’re ready"
      primaryText="Get in touch"
      ghostText="Email directly"
    />
  </div>
</BaseLayout>
