---
import BaseLayout from '../layouts/BaseLayout.astro';
import LabelRow from '../components/LabelRow.astro';
import SectionHead from '../components/SectionHead.astro';
import CtaStrip from '../components/CtaStrip.astro';
import ServiceGlyph from '../components/ServiceGlyph.astro';

const overview = [
  { num: '01', name: 'Foundation', blurb: 'Custom sites & apps', href: '#foundation', tier: 1 },
  { num: '02', name: 'Operations', blurb: 'Automation & tools', href: '#operations', tier: 2 },
  { num: '03', name: 'Intelligence', blurb: 'AI & agents', href: '#intelligence', tier: 3 }
];

const picker = [
  { quote: 'Our website is embarrassing.', tier: 'Foundation', tierKey: 1, href: '#foundation' },
  {
    quote: 'We need an application that fits how we work.',
    tier: 'Foundation',
    tierKey: 1,
    href: '#foundation'
  },
  {
    quote: 'We have tons of data but don’t know how to put it to use.',
    tier: 'Operations',
    tierKey: 2,
    href: '#operations'
  },
  {
    quote: 'We sometimes spend hours at a time manually formatting Excel and Word documents.',
    tier: 'Operations',
    tierKey: 2,
    href: '#operations'
  },
  {
    quote: 'Our tools don\u2019t connect to each other.',
    tier: 'Operations',
    tierKey: 2,
    href: '#operations'
  },
  {
    quote: 'We want to integrate AI but don\u2019t know where to start.',
    tier: 'Intelligence',
    tierKey: 3,
    href: '#intelligence'
  },
  {
    quote: 'We have AI subscriptions nobody uses.',
    tier: 'Intelligence',
    tierKey: 3,
    href: '#intelligence'
  },
  {
    quote: 'Wake me up when AI can do something actually useful.',
    tier: 'Intelligence',
    tierKey: 3,
    href: '#intelligence'
  }
];

const services = [
  {
    id: 'foundation',
    num: '01',
    tier: 1,
    name: 'Foundation',
    title: 'Custom sites & software',
    plain:
      'The basics: a well-designed site that ranks and converts, and software that matches how your team actually works.',
    builds: [
      'Custom sites you\u2019re proud to send people to',
      'Sites designed to rank in search and turn visitors into customers',
      'Custom applications when off-the-shelf doesn\u2019t fit',
      'Client portals and online forms'
    ],
    symptoms: [
      [
        'Our site looks like 2006 and we\u2019re embarrassed to share it.',
        'Something current you\u2019re proud to send people to.'
      ],
      [
        'Nothing off the shelf fits how we actually operate.',
        'Software built for your process from scratch.'
      ]
    ],
    outcome:
      'A polished, search-optimized site that brings in business, and software built around you \u2014 live, owned, and made for your business.'
  },
  {
    id: 'operations',
    num: '02',
    tier: 2,
    name: 'Operations',
    title: 'Automation & internal tools',
    plain:
      'The work that eats your week: moving data between systems, rebuilding the same report, keeping five spreadsheets in sync.',
    builds: [
      'Automatic sync between the tools you already use',
      'Internal dashboards and small apps',
      'Scheduled reports and recurring jobs',
      'A single source of truth that replaces shared spreadsheets'
    ],
    symptoms: [
      [
        'We have eight different versions of the same spreadsheet.',
        'One app serves as a single source of truth.'
      ],
      [
        'Scheduling and reports eat our week.',
        'Automations that run on a schedule and email the results.'
      ]
    ],
    outcome: 'Time back to focus on the bigger picture and data your team can trust.'
  },
  {
    id: 'intelligence',
    num: '03',
    tier: 3,
    name: 'Intelligence',
    title: 'AI integration & custom agents',
    plain:
      'Pick the right AI tool for the job, connect it to your software, and build agents that handle repetitive work — and surface insights and ideas you’d otherwise miss.',
    builds: [
      'The right AI tools, chosen and set up for your team',
      'Custom AI agents that do real work for you',
      'MCP connections that bring AI into the tools you already use',
      'Custom agent skills built for your workflows'
    ],
    symptoms: [
      [
        'We want to integrate AI but don\u2019t know where to start.',
        'Walk through your workflows, pick what fits, and wire it in.'
      ],
      [
        'We ran an AI pilot and it provided little value.',
        'Go beyond chatbots with agentic skills and connectors wired into your real work.'
      ]
    ],
    outcome: 'AI that saves time on real tasks, with a person still in the loop where it matters.',
    credibility:
      'I work daily with Claude, Codex, MCP servers, and agent skills. You don\u2019t need the jargon; you get someone current who helps you pick what fits.',
    caveat:
      'AI works best when your data and tools are in order. I build the whole stack so nothing\u2019s missing.'
  }
];
---

<BaseLayout
  title="Services — Custom Sites, Automation & AI | NSG Solutions"
  description="Custom sites, apps, automation, and AI integration for small businesses in Minneapolis. Custom agents and workflows. One person, end to end."
  breadcrumb={[
    { name: 'Home', href: '/' },
    { name: 'Services', href: '/services' }
  ]}
>
  <div class="page services-page">
    <div class="container">
      <header class="page-head">
        <LabelRow num="SERVICES / 01" meta="What NSG does" />
        <h1>
          I build custom sites, automations, and AI that does real work<span class="accent">.</span>
        </h1>
        <p class="lede">
          NSG is a one-person software and AI practice in Minneapolis. You describe what
          you&rsquo;re looking for. I design, build, and ship it: custom sites, apps, automations,
          and AI wired into your workflows.
        </p>
        <div class="hero-meta svc-hero-meta">
          <div class="hero-meta-cell">
            <div class="key">Practice</div>
            <div class="val">Custom sites &middot; Tools &middot; Automation &middot; AI</div>
          </div>
          <div class="hero-meta-cell">
            <div class="key">Based in</div>
            <div class="val">Minneapolis, MN</div>
          </div>
          <div class="hero-meta-cell">
            <div class="key">Working with</div>
            <div class="val">Small businesses</div>
          </div>
        </div>

        <div class="svc-overview" aria-label="Three service areas">
          {
            overview.map((item) => (
              <a class:list={['svc-overview-card', `svc-overview-${item.tier}`]} href={item.href}>
                <div class="svc-overview-glyph">
                  <ServiceGlyph tier={item.tier as 1 | 2 | 3} />
                </div>
                <div class="svc-overview-text">
                  <span class="svc-overview-num">{item.num}</span>
                  <span class="svc-overview-name">{item.name}</span>
                  <span class="svc-overview-blurb">{item.blurb}</span>
                </div>
              </a>
            ))
          }
        </div>
      </header>
    </div>

    <section class="section svc-picker-section">
      <div class="container">
        <SectionHead num="02 / START HERE" meta="Which sounds like you?">
          <Fragment slot="title">Pick the sentence that matches.</Fragment>
        </SectionHead>

        <div class="svc-picker" role="list">
          {
            picker.map((row) => (
              <a
                class:list={['svc-picker-row', `picker-tier-${row.tierKey}`]}
                href={row.href}
                role="listitem"
              >
                <span class="svc-picker-dot" aria-hidden="true" />
                <span class="svc-picker-quote">&ldquo;{row.quote}&rdquo;</span>
                <span class="svc-picker-arrow" aria-hidden="true">
                  &rarr;
                </span>
                <span class="svc-picker-tier">{row.tier}</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section svc-tiers-section">
      <div class="container">
        <SectionHead num="03 / WHAT I BUILD" meta="Three kinds of work">
          <Fragment slot="title">Three ways I can help.</Fragment>
        </SectionHead>

        {
          services.map((svc) => (
            <article class:list={['svc-tier', `svc-tier-${svc.tier}`]} id={svc.id}>
              <div class="svc-tier-frame">
                <div class="svc-tier-body">
                  <header class="svc-tier-head">
                    <div class="svc-tier-head-row">
                      <div class="svc-tier-glyph">
                        <ServiceGlyph tier={svc.tier as 1 | 2 | 3} />
                      </div>
                      <div class="svc-tier-head-text">
                        <span class="svc-tier-tag">
                          {svc.num} &middot; {svc.name.toUpperCase()}
                        </span>
                        <h2>{svc.title}</h2>
                      </div>
                    </div>
                    <p class="svc-tier-plain">{svc.plain}</p>
                  </header>

                  <div class="svc-tier-grid">
                    <div class="svc-tier-col">
                      <h3 class="svc-tier-label">I build</h3>
                      <ul class="svc-tier-builds">
                        {svc.builds.map((item, i) => (
                          <li>
                            <span class="build-idx" aria-hidden="true">
                              {String(i + 1).padStart(2, '0')}
                            </span>
                            <span>{item}</span>
                          </li>
                        ))}
                      </ul>
                    </div>

                    <div class="svc-tier-col">
                      <h3 class="svc-tier-label">Sound like you?</h3>
                      <ul class="svc-tier-symptoms">
                        {svc.symptoms.map(([quote, fix]) => (
                          <li>
                            <span class="symptom-mark" aria-hidden="true">
                              &ldquo;
                            </span>
                            <div>
                              <span class="quote">{quote}</span>
                              <span class="fix">&rarr; {fix}</span>
                            </div>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>

                  <div class="svc-tier-outcome">
                    <span class="outcome-mark" aria-hidden="true">
                      ✓
                    </span>
                    <p>
                      <strong>What you get:</strong> {svc.outcome}
                    </p>
                  </div>

                  {svc.credibility && <p class="svc-tier-cred">{svc.credibility}</p>}

                  {svc.caveat && <p class="svc-tier-caveat">{svc.caveat}</p>}
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section svc-stack-section" id="the-stack">
      <div class="container">
        <SectionHead num="04 / THE STACK" meta="How it fits together">
          <Fragment slot="title">AI works two ways.</Fragment>
        </SectionHead>

        <div class="svc-stack-wrap">
          <div class="svc-stack-viz" aria-hidden="true">
            <div class="stack-block stack-block-intel">
              <span class="stack-block-num">03</span>
              <span class="stack-block-name">Intelligence</span>
              <span class="stack-block-note">Agents &middot; MCP &middot; skills</span>
            </div>
            <div class="svc-stack-base">
              <div class="svc-stack-layers">
                <div class="stack-block stack-block-2">
                  <span class="stack-block-num">02</span>
                  <span class="stack-block-name">Operations</span>
                  <span class="stack-block-note"
                    >Marketing &middot; dashboards &middot; reports</span
                  >
                </div>
                <div class="stack-block stack-block-1">
                  <span class="stack-block-num">01</span>
                  <span class="stack-block-name">Foundation</span>
                  <span class="stack-block-note">Sites &middot; apps &middot; portals</span>
                </div>
              </div>
              <div class="svc-stack-spine">
                <span class="svc-stack-spine-stack">
                  <span class="svc-stack-spine-label">AI</span>
                  <span class="svc-stack-spine-note">Fast &middot; cheap &middot; automation</span>
                </span>
              </div>
            </div>
          </div>

          <div class="svc-stack-copy">
            <p>
              <strong>It makes the rest faster.</strong> AI speeds up building the site, runs inside your
              apps, and cuts the manual work out of your day to day. Not a separate project bolted on
              top.
            </p>
            <p>
              <strong>And it&rsquo;s a craft of its own.</strong> Custom agents, MCP servers, and skills
              that do real work for your business. We start with what makes sense for you &mdash; AI,
              a custom site, or anything in between.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section svc-process-section">
      <div class="container">
        <SectionHead num="05 / HOW IT WORKS" meta="How it goes">
          <Fragment slot="title">How this works.</Fragment>
        </SectionHead>

        <div class="svc-process-prose">
          <p>
            We scope it together: what&rsquo;s in the way, what &ldquo;done&rdquo; looks like,
            whether it&rsquo;s worth doing yet. No pressure, and you get a clear quote before any
            work starts.
          </p>
          <p>
            When you&rsquo;re ready, I build it &mdash; and we stay close. You see progress as it
            comes together, and we course-correct as we go, so nothing&rsquo;s a surprise at the
            end. When it&rsquo;s done, it all transfers to you: the code, the access, all of it. And
            I&rsquo;m still here for whatever comes next.
          </p>
        </div>

        <p class="svc-process-more">
          More on how NSG works on the <a href="/about">about page</a>.
        </p>
      </div>
    </section>

    <CtaStrip
      title="Still figuring things out? <span class='cta-answer'>That’s what I’m here for.</span>"
      note="Let’s think through it together. Two business-day reply."
      primaryText="Send a note"
    />
  </div>
</BaseLayout>
