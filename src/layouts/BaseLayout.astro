---
import '../styles/global.css';
import '../styles/additions.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'NSG — Custom software for small businesses',
  description = 'NSG Solutions builds custom software, automations, AI integrations, and connected tools for small businesses.'
} = Astro.props;

const rawPath = Astro.url.pathname
  .replace(/\.html$/, '')
  .replace(/\/index$/, '/')
  .replace(/\/$/, '');
const path = rawPath === '' ? '/' : rawPath;
const siteUrl = Astro.site ?? new URL('https://nsgsolutions.co');
const canonical = new URL(path, siteUrl).toString();
const ogImage = new URL('/assets/og-image.png?v=2', siteUrl).toString();

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': new URL('/#organization', siteUrl).toString(),
  name: 'NSG Solutions',
  alternateName: 'NSG',
  url: siteUrl.toString(),
  logo: new URL('/assets/nsg-mark.svg', siteUrl).toString(),
  image: ogImage,
  email: 'noah@nsgsolutions.co',
  description: 'NSG Solutions builds custom software, automations, AI integrations, and connected tools for small businesses.',
  founder: {
    '@type': 'Person',
    name: 'Noah Greensweig',
    url: 'https://www.linkedin.com/in/noah-greensweig'
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Minneapolis',
    addressRegion: 'MN',
    addressCountry: 'US'
  },
  areaServed: [
    { '@type': 'City', name: 'Minneapolis' },
    { '@type': 'AdministrativeArea', name: 'Minnesota' },
    { '@type': 'Country', name: 'United States' }
  ],
  sameAs: ['https://www.linkedin.com/in/noah-greensweig']
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="NSG Solutions — custom software, built by hand" />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NSG Solutions" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="NSG Solutions — custom software, built by hand" />
    <link rel="icon" href="/assets/favicon-red-dot.svg?v=small-preview" type="image/svg+xml" sizes="any" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href="/fonts/JetBrainsMono-Latin.woff2" as="font" type="font/woff2" crossorigin />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </head>
  <body>
    <Nav currentPath={path} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
