---
import '../styles/global.css';
import '../styles/additions.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  breadcrumb?: { name: string; href: string }[];
}

const {
  title = 'NSG — Software & AI for small businesses',
  description = 'NSG Solutions builds custom sites, internal tools, automations, and AI integrations for small businesses. Custom agents and workflows. One person, end to end.',
  noindex = false,
  breadcrumb
} = Astro.props;

const rawPath = Astro.url.pathname
  .replace(/\.html$/, '')
  .replace(/\/index$/, '/')
  .replace(/\/$/, '');
const path = rawPath === '' ? '/' : rawPath;
const siteUrl = Astro.site ?? new URL('https://nsgsolutions.co');
const canonical = new URL(path, siteUrl).toString().replace(/\/$/, '');
const homeUrl = siteUrl.toString().replace(/\/$/, '');
const ogImage = new URL('/assets/og-image.png?v=3', siteUrl).toString();

const orgId = new URL('/#organization', siteUrl).toString();
const websiteId = new URL('/#website', siteUrl).toString();
const webpageId = `${canonical}#webpage`;

const orgSchema = {
  '@type': 'ProfessionalService',
  '@id': orgId,
  name: 'NSG Solutions',
  alternateName: 'NSG',
  url: siteUrl.toString(),
  logo: new URL('/assets/nsg-mark.svg', siteUrl).toString(),
  image: ogImage,
  email: 'noah@nsgsolutions.co',
  priceRange: '$$-$$$',
  description:
    'NSG Solutions builds custom sites, internal tools, automations, and AI integrations for small businesses. Custom agents and workflows. One person, end to end.',
  founder: {
    '@type': 'Person',
    name: 'Noah Greensweig',
    url: 'https://www.linkedin.com/in/noah-greensweig'
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Minneapolis',
    addressRegion: 'MN',
    addressCountry: 'US'
  },
  areaServed: [
    { '@type': 'City', name: 'Minneapolis' },
    { '@type': 'AdministrativeArea', name: 'Minnesota' },
    { '@type': 'Country', name: 'United States' }
  ],
  sameAs: ['https://www.linkedin.com/in/noah-greensweig']
};

const websiteSchema = {
  '@type': 'WebSite',
  '@id': websiteId,
  url: siteUrl.toString(),
  name: 'NSG Solutions',
  publisher: { '@id': orgId },
  inLanguage: 'en-US'
};

const webpageSchema = {
  '@type': 'WebPage',
  '@id': webpageId,
  url: canonical,
  name: title,
  description,
  isPartOf: { '@id': websiteId },
  about: { '@id': orgId },
  inLanguage: 'en-US',
  primaryImageOfPage: { '@type': 'ImageObject', url: ogImage }
};

const breadcrumbSchema =
  breadcrumb && breadcrumb.length > 0
    ? {
        '@type': 'BreadcrumbList',
        '@id': `${canonical}#breadcrumb`,
        itemListElement: breadcrumb.map((crumb, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: crumb.name,
          item: new URL(crumb.href, siteUrl).toString()
        }))
      }
    : null;

const graph = [orgSchema, websiteSchema, webpageSchema, breadcrumbSchema].filter(Boolean);
const jsonLd = { '@context': 'https://schema.org', '@graph': graph };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#D72638" />
    <meta name="color-scheme" content="light" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    {!noindex && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="NSG Solutions — modern software for small businesses" />
    <meta property="og:url" content={noindex ? homeUrl : canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NSG Solutions" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="NSG Solutions — modern software for small businesses" />
    <link rel="icon" href="/assets/favicon.svg?v=wordmark" type="image/svg+xml" sizes="any" />
    <link rel="apple-touch-icon" href="/assets/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link
      rel="preload"
      href="/fonts/BeVietnamPro-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/BeVietnamPro-Medium.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/LibreBaskerville-Italic.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/JetBrainsMono-Latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {!noindex && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <Nav currentPath={path} />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Selectors that should fade-up into view as you scroll.
      // Children of a group get a small stagger via --reveal-delay.
      const groups: Array<{ selector: string; staggerMs?: number }> = [
        { selector: '.problems .tier-group', staggerMs: 80 },
        { selector: '.problems-list .problem', staggerMs: 60 },
        { selector: '.principle-grid .principle', staggerMs: 80 },
        { selector: '.work-list .work-card', staggerMs: 90 },
        { selector: '.svc-tier' },
        { selector: '.svc-overview .svc-overview-card', staggerMs: 70 },
        { selector: '.svc-picker .svc-picker-row', staggerMs: 50 },
        { selector: '.svc-stack-viz > *', staggerMs: 50 },
        { selector: '.svc-steps .svc-step', staggerMs: 60 },
        { selector: '.about-overview .svc-overview-card', staggerMs: 70 },
        { selector: '.about-commitment-tier', staggerMs: 80 },
        { selector: '.about-fit-list li', staggerMs: 40 },
        { selector: '.about-stack-mini .row', staggerMs: 50 }
      ];

      const singletons = [
        '.section-head',
        '.label-row',
        '.page-head',
        '.manifesto h2',
        '.cta-inner',
        '.tier-intro'
      ];

      function tag(el: Element, delayMs = 0) {
        el.classList.add('reveal');
        if (delayMs > 0) {
          (el as HTMLElement).style.setProperty('--reveal-delay', `${delayMs}ms`);
        }
      }

      // Tag elements
      for (const { selector, staggerMs } of groups) {
        const nodes = document.querySelectorAll(selector);
        nodes.forEach((node, i) => {
          // For grouped items inside the same parent, stagger relative
          // to position among siblings matching the same selector.
          tag(node, staggerMs ? Math.min(i, 6) * staggerMs : 0);
        });
      }

      for (const selector of singletons) {
        document.querySelectorAll(selector).forEach((node) => tag(node));
      }

      // Hero one-shot: fire after first paint
      requestAnimationFrame(() => {
        document.body.classList.add('hero-loaded');
      });

      if (prefersReduced) {
        // Reveal everything immediately; CSS already neutralizes transitions.
        document.querySelectorAll('.reveal').forEach((n) => n.classList.add('is-in'));
      } else if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-in');
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
        );

        document.querySelectorAll('.reveal').forEach((n) => {
          // If already on screen at load (above-the-fold), reveal without delay-in.
          const rect = n.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.92) {
            n.classList.add('is-in');
          } else {
            io.observe(n);
          }
        });
      } else {
        document.querySelectorAll('.reveal').forEach((n) => n.classList.add('is-in'));
      }
    </script>
  </body>
</html>
